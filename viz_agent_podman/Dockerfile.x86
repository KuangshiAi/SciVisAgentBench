# syntax=docker/dockerfile:1
FROM --platform=linux/amd64 ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Basic build and runtime dependencies
RUN apt-get update && apt-get install -y \
    wget \
    curl \
    git \
    ca-certificates \
    bzip2 \
    libgl1 \
    libxrender1 \
    libxext6 \
    libsm6 \
    xvfb \
    && rm -rf /var/lib/apt/lists/*

# -------- Install Mambaforge (conda with mamba), architecture aware --------
ENV MAMBA_VERSION=23.11.0-0
ENV CONDA_DIR=/opt/conda

# Force x86_64 installer
RUN installer="Mambaforge-${MAMBA_VERSION}-Linux-x86_64.sh" && \
    echo "Installing x86_64 Mambaforge" && \
    wget https://github.com/conda-forge/miniforge/releases/download/${MAMBA_VERSION}/${installer} -O /tmp/mambaforge.sh && \
    bash /tmp/mambaforge.sh -b -p ${CONDA_DIR} && \
    rm /tmp/mambaforge.sh

ENV PATH=${CONDA_DIR}/bin:${PATH}
SHELL ["/bin/bash", "-c"]

# -------- Environment file --------
COPY environment.yml /tmp/environment.yml

RUN mamba env create -f /tmp/environment.yml && \
    mamba clean -a -y

# Activate this environment by default
ENV CONDA_DEFAULT_ENV=viz-agent
ENV PATH=${CONDA_DIR}/envs/viz-agent/bin:${PATH}

# -------- ParaView installation --------
ENV PARAVIEW_VERSION=5.12.0
ENV PARAVIEW_DIR=/opt/paraview

# Install ParaView x86_64 binary
RUN wget https://www.paraview.org/files/v${PARAVIEW_VERSION}/ParaView-${PARAVIEW_VERSION}-osmesa-MPI-Linux-Python3.10-x86_64.tar.gz -O /tmp/paraview.tar.gz && \
    mkdir -p ${PARAVIEW_DIR} && \
    tar -xzf /tmp/paraview.tar.gz -C ${PARAVIEW_DIR} --strip-components=1 && \
    rm /tmp/paraview.tar.gz

ENV PATH=${PARAVIEW_DIR}/bin:${PATH}
ENV LD_LIBRARY_PATH=${PARAVIEW_DIR}/lib:${LD_LIBRARY_PATH}
ENV PYTHONPATH=${PARAVIEW_DIR}/lib/python3.10/site-packages:${PYTHONPATH}

WORKDIR /workspace

# Test ParaView import
RUN python -c "import paraview.simple as pvs; print('ParaView version:', pvs.GetParaViewVersion().GetVersion())"

CMD ["/bin/bash"]
